            {
              "name": "Stats - Available Rooms",
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "// Visualization Script",
                      "// Visualization Script",
                      "const template = `",
                      "<div style=\"font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Arial, sans-serif; padding: 24px; background: #f6f8fb; min-height: 100vh; box-sizing: border-box;\">",
                      "  <div style=\"max-width: 480px; margin: 0 auto;\">",
                      "    <div style=\"background: #ffffff; border: 1px solid #e6ebf1; border-radius: 16px; padding: 24px; box-shadow: 0 4px 14px rgba(0,0,0,0.06);\">",
                      "      <div style=\"font-size: 14px; color: #6b7280; margin-bottom: 8px;\">Stats Dashboard</div>",
                      "      <div style=\"font-size: 28px; font-weight: 700; color: #111827; margin-bottom: 20px;\">Active Bookings</div>",
                      "      <div style=\"display: inline-block; background: #eef6ff; color: #1d4ed8; font-size: 13px; font-weight: 600; padding: 6px 10px; border-radius: 999px; margin-bottom: 16px;\">Current Total</div>",
                      "      <div style=\"font-size: 56px; line-height: 1; font-weight: 800; color: #0f172a;\">{{active_bookings}}</div>",
                      "      <div style=\"margin-top: 16px; font-size: 13px; color: #6b7280;\">Status: {{statusLabel}}</div>",
                      "    </div>",
                      "  </div>",
                      "</div>`;",
                      "",
                      "function createPayload() {",
                      "  let data = {};",
                      "",
                      "  try {",
                      "    data = pm.response.json();",
                      "  } catch (e) {",
                      "    data = {};",
                      "  }",
                      "",
                      "  const activeBookingsRaw = data && data.active_bookings !== undefined && data.active_bookings !== null",
                      "    ? data.active_bookings",
                      "    : 'N/A';",
                      "",
                      "  return {",
                      "    active_bookings: String(activeBookingsRaw),",
                      "    statusLabel: data && data.status === true ? 'Success' : 'Unavailable'",
                      "  };",
                      "}",
                      "",
                      "pm.visualizer.set(template, createPayload());"
                    ],
                    "type": "text/javascript",
                    "packages": {},
                    "requests": {}
                  }
                }
              ],
              "request": {
                "method": "GET",
                "header": [],
                "url": {
